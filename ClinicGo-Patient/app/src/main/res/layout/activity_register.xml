<?xml version="1.0" encoding="utf-8"?>
<!-- activity_register.xml -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F3F4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A1C1C"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending receptionist approval after signup"
            android:textSize="13sp"
            android:textColor="#717783"
            android:layout_marginBottom="24dp" />

        <TextView android:id="@+id/tv_error"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_error" android:padding="12dp"
            android:textColor="#BA1A1A" android:textSize="13sp"
            android:visibility="gone" android:layout_marginBottom="16dp" />

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:background="@drawable/bg_card" android:padding="24dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="FULL NAME" android:textSize="11sp" android:textStyle="bold"
                android:textColor="#414752" android:layout_marginBottom="8dp" />
            <EditText android:id="@+id/et_name" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="@drawable/bg_input"
                android:padding="14dp" android:hint="Riya Sharma"
                android:textSize="14sp" android:layout_marginBottom="16dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="EMAIL ADDRESS" android:textSize="11sp" android:textStyle="bold"
                android:textColor="#414752" android:layout_marginBottom="8dp" />
            <EditText android:id="@+id/et_email" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="@drawable/bg_input"
                android:padding="14dp" android:hint="you@email.com"
                android:inputType="textEmailAddress" android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="PHONE NUMBER" android:textSize="11sp" android:textStyle="bold"
                android:textColor="#414752" android:layout_marginBottom="8dp" />
            <EditText android:id="@+id/et_phone" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="@drawable/bg_input"
                android:padding="14dp" android:hint="9876543210"
                android:inputType="phone" android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="PASSWORD" android:textSize="11sp" android:textStyle="bold"
                android:textColor="#414752" android:layout_marginBottom="8dp" />
            <EditText android:id="@+id/et_password" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="@drawable/bg_input"
                android:padding="14dp" android:hint="Min 6 characters"
                android:inputType="textPassword" android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="CONFIRM PASSWORD" android:textSize="11sp" android:textStyle="bold"
                android:textColor="#414752" android:layout_marginBottom="8dp" />
            <EditText android:id="@+id/et_confirm_password" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="@drawable/bg_input"
                android:padding="14dp" android:hint="Re-enter password"
                android:inputType="textPassword" android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <ProgressBar android:id="@+id/progress_bar"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <Button android:id="@+id/btn_register"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:background="@drawable/bg_button_primary"
                android:text="Continue to Step 3" android:textColor="#FFFFFF"
                android:textSize="15sp" android:textStyle="bold" />
        </LinearLayout>

        <TextView android:id="@+id/tv_login"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Already have an account? Sign in"
            android:textSize="13sp" android:textColor="#005DAC"
            android:layout_marginTop="16dp" android:padding="8dp"
            android:layout_gravity="center_horizontal" />
    </LinearLayout>
</ScrollView>
