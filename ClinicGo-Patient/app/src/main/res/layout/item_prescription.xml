<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top accent bar -->
        <View
            android:layout_width="32dp"
            android:layout_height="3dp"
            android:background="#1976D2"
            android:layout_marginBottom="10dp" />

        <!-- Doctor + date row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_doctor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dr. Anil Mehta"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1C1C" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15 Jun"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_chip_blue"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

        </LinearLayout>

        <!-- Diagnosis -->
        <TextView
            android:id="@+id/tv_diagnosis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Viral fever"
            android:textSize="13sp"
            android:textColor="#414752"
            android:layout_marginTop="8dp"
            android:lineSpacingMultiplier="1.3" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp" />

        <!-- Medicine count -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💊 "
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_medicines"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 medicines prescribed"
                android:textSize="12sp"
                android:textColor="#1976D2"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>