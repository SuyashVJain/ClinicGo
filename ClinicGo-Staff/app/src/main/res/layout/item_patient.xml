<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/bg_card"
    android:padding="16dp" android:layout_marginBottom="8dp">
    <TextView android:id="@+id/tv_name" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textSize="15sp"
        android:textStyle="bold" android:textColor="#1A1C1C"/>
    <TextView android:id="@+id/tv_email" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textSize="12sp"
        android:textColor="#717783" android:layout_marginTop="2dp"/>
    <TextView android:id="@+id/tv_phone" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textSize="12sp"
        android:textColor="#717783" android:layout_marginTop="2dp"/>
    <Button android:id="@+id/btn_approve" android:layout_width="match_parent"
        android:layout_height="38dp" android:background="@drawable/bg_button_primary"
        android:text="Approve Patient" android:textColor="#FFFFFF"
        android:textSize="13sp" android:layout_marginTop="10dp"/>
</LinearLayout>
